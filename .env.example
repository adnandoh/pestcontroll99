# CRM API — leave empty in dev to use Vite proxy, then production fallback
VITE_CRM_API_URL=https://api.vacationbna.site
# NEXT_PUBLIC_CRM_API_URL=https://api.vacationbna.site

# Google Maps (Vite reads VITE_*; NEXT_PUBLIC_* is also supported for legacy .env)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Analytics
VITE_GA_ID=G-69K3FRS21R
VITE_ENABLE_ANALYTICS=true
